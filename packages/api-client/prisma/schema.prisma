generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum ActivityType {
  cycling
  hiking
  trail_running
  skiing
  snowboarding
  kayaking
  climbing
  other
}

enum POICategory {
  hotel
  hostel
  campsite
  guesthouse
  restaurant
  cafe
  bar
  bike_shop
  trailhead
  viewpoint
  other
}

enum NotificationType {
  like_post
  like_trip
  comment
  follow
  review_poi
}

// ─────────────────────────────────────────────
// User & Social
// ─────────────────────────────────────────────

model User {
  id             String         @id @default(uuid())
  /// Matches the Supabase Auth user id
  authId         String         @unique
  username       String         @unique
  displayName    String
  avatarUrl      String?
  bio            String?
  location       String?
  activityTypes  ActivityType[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  trips                   Trip[]
  posts                   Post[]
  reviews                 Review[]
  stageReviews            StageReview[]
  comments                Comment[]
  postLikes               PostLike[]
  tripLikes               TripLike[]
  following               Follow[]                   @relation("follower")
  followers               Follow[]                   @relation("following")
  notifications           Notification[]
  createdPOIs             POI[]
  adventures              Adventure[]
  adventurePreferences    UserAdventurePreferences?

  @@map("users")
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@map("follows")
}

// ─────────────────────────────────────────────
// Trips & Stages
// ─────────────────────────────────────────────

model Trip {
  id            String       @id @default(uuid())
  userId        String
  title         String
  description   String?
  startDate     DateTime     @db.Date
  endDate       DateTime     @db.Date
  region        String
  coverImageUrl String?
  activityType  ActivityType
  isPublished   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  stages       Stage[]
  posts        Post[]
  reviews      Review[]
  stageReviews StageReview[]
  likes        TripLike[]

  @@map("trips")
}

model Stage {
  id             String   @id @default(uuid())
  tripId         String
  title          String
  date           DateTime @db.Date
  distanceKm     Float?
  elevationGainM Float?
  /// URL to GPX file stored in Supabase Storage
  routeGpxUrl    String?
  notes          String?
  orderIndex     Int
  createdAt      DateTime @default(now())

  trip         Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  posts        Post[]
  stageReviews StageReview[]

  @@map("stages")
}

// ─────────────────────────────────────────────
// Points of Interest
// ─────────────────────────────────────────────

model POI {
  id            String       @id @default(uuid())
  name          String
  category      POICategory
  /// Latitude
  lat           Float
  /// Longitude
  lng           Float
  address       String?
  website       String?
  activityTypes ActivityType[]
  createdById   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  createdBy        User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  reviews          Review[]
  postMentions     PostPOIMention[]
  adventureDayPOIs AdventureDayPOI[]

  @@map("pois")
}

// ─────────────────────────────────────────────
// Reviews
// ─────────────────────────────────────────────

model Review {
  id              String   @id @default(uuid())
  userId          String
  poiId           String
  tripId          String?
  rating          Int
  wouldRecommend  Boolean
  pros            String[]
  cons            String[]
  body            String?
  /// Granular category-specific attribute scores stored as JSON
  /// e.g. { "cleanliness": 4, "comfort": 5, "value": 3 }
  attributes      Json     @default("{}")
  visitedAt       DateTime @db.Date
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  poi   POI   @relation(fields: [poiId], references: [id], onDelete: Cascade)
  trip  Trip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@unique([userId, poiId, visitedAt])
  @@map("reviews")
}

// ─────────────────────────────────────────────
// Social Feed
// ─────────────────────────────────────────────

model Post {
  id         String   @id @default(uuid())
  userId     String
  tripId     String?
  stageId    String?
  body       String
  mediaUrls  String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip        Trip?            @relation(fields: [tripId], references: [id], onDelete: SetNull)
  stage       Stage?           @relation(fields: [stageId], references: [id], onDelete: SetNull)
  likes       PostLike[]
  comments    Comment[]
  poiMentions PostPOIMention[]

  @@map("posts")
}

model PostPOIMention {
  postId String
  poiId  String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  poi  POI  @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@id([postId, poiId])
  @@map("post_poi_mentions")
}

model PostLike {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@map("post_likes")
}

model TripLike {
  userId    String
  tripId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@id([userId, tripId])
  @@map("trip_likes")
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  body      String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

// ─────────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────────

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType
  /// ID of the related entity (post, trip, user etc.)
  referenceId String
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─────────────────────────────────────────────
// Stage Reviews (rating route segments)
// ─────────────────────────────────────────────

model StageReview {
  id             String   @id @default(uuid())
  stageId        String
  userId         String
  tripId         String?
  rating         Int
  difficulty     Int?
  scenery        Int?
  surfaceQuality Int?
  /// 1 = no traffic, 5 = heavy traffic
  trafficLevel   Int?
  body           String?
  wouldRepeat    Boolean  @default(true)
  visitedAt      DateTime @db.Date
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stage Stage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip  Trip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@unique([userId, stageId])
  @@map("stage_reviews")
}

// ─────────────────────────────────────────────
// User Adventure Preferences
// ─────────────────────────────────────────────

model UserAdventurePreferences {
  userId                   String       @id
  fitnessLevel             String       @default("intermediate")
  preferredActivityTypes   ActivityType[]
  preferredDailyDistanceKm Float?
  preferredDailyElevationM Float?
  accommodationPreference  String       @default("mid_range")
  groupSize                Int          @default(1)
  dietaryNotes             String?
  otherNotes               String?
  updatedAt                DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_adventure_preferences")
}

// ─────────────────────────────────────────────
// Adventures (AI-generated itineraries)
// ─────────────────────────────────────────────

model Adventure {
  id            String       @id @default(uuid())
  userId        String
  title         String
  description   String?
  region        String
  activityType  ActivityType
  durationDays  Int
  startDate     DateTime?    @db.Date
  requestPrompt String
  isSaved       Boolean      @default(false)
  createdAt     DateTime     @default(now())

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  days AdventureDay[]

  @@map("adventures")
}

model AdventureDay {
  id             String  @id @default(uuid())
  adventureId    String
  dayNumber      Int
  title          String
  description    String?
  distanceKm     Float?
  elevationGainM Float?
  routeNotes     String?

  adventure Adventure          @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  pois      AdventureDayPOI[]

  @@unique([adventureId, dayNumber])
  @@map("adventure_days")
}

model AdventureDayPOI {
  id             String @id @default(uuid())
  adventureDayId String
  poiId          String
  /// accommodation | lunch | dinner | breakfast | start | end | highlight | rest_stop
  role           String
  notes          String?
  orderIndex     Int    @default(0)

  adventureDay AdventureDay @relation(fields: [adventureDayId], references: [id], onDelete: Cascade)
  poi          POI          @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@map("adventure_day_pois")
}
