{
  "buildCommand": "cd ../.. && pnpm --filter web build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "crons": [
    {
      "path": "/api/admin/chips/recompute",
      "schedule": "0 2 * * 1"
    }
  ],
  "functions": {
    "app/api/admin/adventures/generate/route.ts": {
      "maxDuration": 300
    },
    "app/api/admin/curate/route.ts": {
      "maxDuration": 300
    },
    "app/api/adventures/chat/route.ts": {
      "maxDuration": 60
    },
    "app/api/discovery/destinations/route.ts": {
      "maxDuration": 60
    },
    "app/api/discovery/itinerary-skeleton/route.ts": {
      "maxDuration": 30
    },
    "app/api/admin/chips/recompute/route.ts": {
      "maxDuration": 300
    }
  }
}
